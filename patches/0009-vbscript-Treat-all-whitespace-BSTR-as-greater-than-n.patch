From de0d8c8cf12dfa190406948dbe2c414885d73c0f Mon Sep 17 00:00:00 2001
From: Francis De Brabandere <francisdb@gmail.com>
Date: Mon, 4 May 2026 23:43:43 +0200
Subject: [PATCH] vbscript: Treat all-whitespace BSTR as greater than numeric
 in non-literal compare.

Native VBScript sorts a non-empty all-whitespace BSTR (Space, tab, LF,
CR, ...) higher than any numeric or boolean operand, regardless of the
binary lex order their CStr forms would produce. Add an early-out in
var_cmp before the CStr-coerce path; empty BSTR keeps falling through
to the regular lex compare.
---
 dlls/vbscript/interp.c | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/dlls/vbscript/interp.c b/dlls/vbscript/interp.c
index d8a84360703..06a42acbb13 100644
--- a/dlls/vbscript/interp.c
+++ b/dlls/vbscript/interp.c
@@ -2240,9 +2240,19 @@ static HRESULT var_cmp(exec_ctx_t *ctx, VARIANT *l, VARIANT *r, unsigned flags)
        (rvt == VT_BSTR && (is_numeric_vt(lvt) || lvt == VT_BOOL))) {
         VARIANT *num = lvt == VT_BSTR ? r : l;
         VARIANT *str = lvt == VT_BSTR ? l : r;
+        BSTR str_bstr = V_BSTR(str);
         VARIANT num_str;
         HRESULT hres;

+        /* Native treats a non-empty all-whitespace BSTR as greater than
+         * any numeric or boolean, regardless of binary lex order. */
+        if(str_bstr && *str_bstr) {
+            const WCHAR *p;
+            for(p = str_bstr; *p && iswspace(*p); p++);
+            if(!*p)
+                return lvt == VT_BSTR ? VARCMP_GT : VARCMP_LT;
+        }
+
         VariantInit(&num_str);
         if((V_VT(num) & VT_TYPEMASK) == VT_BOOL) {
             V_VT(&num_str) = VT_BSTR;
--
2.54.0

