From ce55cfca006bb35b8479f69c8ff86e8707500a33 Mon Sep 17 00:00:00 2001
From: Francis De Brabandere <francisdb@gmail.com>
Date: Fri, 17 Apr 2026 22:11:41 +0200
Subject: [PATCH 5/8] vbscript: Log call stack trace on runtime errors.

---
 dlls/vbscript/interp.c | 13 +++++++++++++
 1 file changed, 13 insertions(+)

diff --git a/dlls/vbscript/interp.c b/dlls/vbscript/interp.c
index 490b8508410..93c997d8a94 100644
--- a/dlls/vbscript/interp.c
+++ b/dlls/vbscript/interp.c
@@ -3026,9 +3026,22 @@ HRESULT exec_script(script_ctx_t *ctx, BOOL extern_caller, function_t *func, vbd
                 continue;
             }else {
                 if(!ctx->error_loc_code) {
+                    unsigned line = exec.code->start_line + 1;
+                    const WCHAR *nl;
+                    for(nl = exec.code->source; nl < exec.code->source + exec.instr->loc; nl++)
+                        if(*nl == '\n') line++;
+                    WARN("error 0x%08lx in %s, line %u\n", hres,
+                         exec.func->name ? debugstr_w(exec.func->name) : "<global>", line);
                     grab_vbscode(exec.code);
                     ctx->error_loc_code = exec.code;
                     ctx->error_loc_offset = exec.instr->loc;
+                }else {
+                    unsigned line = exec.code->start_line + 1;
+                    const WCHAR *nl;
+                    for(nl = exec.code->source; nl < exec.code->source + exec.instr->loc; nl++)
+                        if(*nl == '\n') line++;
+                    WARN("  called from %s, line %u\n",
+                         exec.func->name ? debugstr_w(exec.func->name) : "<global>", line);
                 }
                 stack_popn(&exec, exec.top);
                 break;
