Subject: [PATCH 09/13] vbscript: Include function name and line in resume-next

---
 dlls/vbscript/interp.c | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/dlls/vbscript/interp.c b/dlls/vbscript/interp.c
index adcc83cc3ff..010c5cd9b02 100644
--- a/dlls/vbscript/interp.c
+++ b/dlls/vbscript/interp.c
@@ -2858,8 +2858,13 @@ HRESULT exec_script(script_ctx_t *ctx, BOOL extern_caller, function_t *func, vbd
 
             if(exec.resume_next) {
                 unsigned stack_off;
+                unsigned line = exec.code->start_line + 1;
+                const WCHAR *nl;
+                for(nl = exec.code->source; nl < exec.code->source + exec.instr->loc; nl++)
+                    if(*nl == '\n') line++;
 
-                WARN("Failed %08lx in resume next mode\n", ctx->ei.scode);
+                WARN("Failed %08lx in resume next mode in %s, line %u\n", ctx->ei.scode,
+                     exec.func->name ? debugstr_w(exec.func->name) : "<global>", line);
 
