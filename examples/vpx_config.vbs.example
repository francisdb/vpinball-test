' Machine-local config for the vpinball test framework.
'
' Copy this file to vpx_config.vbs and edit the paths to match your
' local checkout. vpx_config.vbs is gitignored; this .example file is
' the template checked into the repo.
'
'   VPINBALL_DIR  - the vpinball source tree (used by the framework
'                   to serve core.vbs, controller.vbs, WPC.vbs, ...
'                   via GetTextFile() pointing at <VPINBALL_DIR>\scripts\).
'   TABLES_DIR    - the parent directory containing one folder per
'                   extracted VPX table (from `vpxtool extract`).
'
' Use native Linux paths (e.g. /home/you/vpinball). Wine accepts these
' as-is via wineprefix; the libwinevbs runner needs them. The older
' Z:\path\to\... form works under wine but breaks under libwinevbs --
' avoid it.
'
Option Explicit

Dim VPINBALL_DIR : VPINBALL_DIR = "/path/to/vpinball"
Dim TABLES_DIR   : TABLES_DIR   = "/path/to/tables"
