From e642292bc269ccf69c1ddf3ec6ee3e25226b6b67 Mon Sep 17 00:00:00 2001
From: Francis De Brabandere <francisdb@gmail.com>
Date: Sun, 3 May 2026 18:36:55 +0200
Subject: [PATCH] fix: pass VARIANT args through with VariantCopyInd, not
 VariantChangeType(..., VT_VARIANT)

Four hand-written proxy methods were calling VariantChangeType with
VT_VARIANT as the destination type:

  wine/dlls/vbscript/regexp_proxy.c    (RegExp2 Replace, replaceVar arg)
  wine/dlls/scrrun/filesystem_proxy.c  (DriveCollection.Item Key arg)
  wine/dlls/scrrun/filesystem_proxy.c  (FileCollection.Item Key arg)
  wine/dlls/scrrun/filesystem_proxy.c  (FolderCollection.Item Key arg)

VT_VARIANT is not a valid conversion target -- VariantChangeType
silently fails, leaving the destination VARIANT VT_EMPTY. Concretely
this made every RegExp.Replace return "" (a single matching call eats
the matched substring and substitutes nothing), and made
Drives.Item/Files.Item/SubFolders.Item lookups receive an empty key.

Replace each VariantChangeType(..., VT_VARIANT) with VariantCopyInd,
which preserves the original VARIANT (resolving any VT_BYREF). The
downstream impl then does its own coercion (e.g. RegExp2_Replace
internally VariantChangeType's the replacement to VT_BSTR).

Repro for the regex case (returns empty before, "X" after):

  Dim re : Set re = New RegExp
  re.Pattern = "[a-z]+"
  WScript.Echo re.Replace("hello", "X")    ' "" before, "X" after
---
 wine/dlls/scrrun/filesystem_proxy.c | 6 +++---
 wine/dlls/vbscript/regexp_proxy.c   | 2 +-
 2 files changed, 4 insertions(+), 4 deletions(-)

diff --git a/wine/dlls/scrrun/filesystem_proxy.c b/wine/dlls/scrrun/filesystem_proxy.c
index 5954976..33b6f9c 100644
--- a/wine/dlls/scrrun/filesystem_proxy.c
+++ b/wine/dlls/scrrun/filesystem_proxy.c
@@ -219,7 +219,7 @@ static HRESULT WINAPI drivecoll_Invoke(IDriveCollection *iface, DISPID dispIdMem
 				// line 213: [id(DISPID_VALUE), propget]HRESULT Item([in] VARIANT Key, [out, retval] IDrive** ppdrive);
 				VARIANT var0;
 				V_VT(&var0) = VT_EMPTY;
-				VariantChangeType(&var0, &pDispParams->rgvarg[--index], 0, VT_VARIANT);
+				VariantCopyInd(&var0, &pDispParams->rgvarg[--index]);
 				V_VT(&res) = VT_DISPATCH;
 				hres = drivecoll_get_Item(iface, var0, (IDrive**)&V_DISPATCH(&res));
 				VariantClear(&var0);
@@ -1219,7 +1219,7 @@ static HRESULT WINAPI filecoll_Invoke(IFileCollection *iface, DISPID dispIdMembe
 				// line 441: [id(DISPID_VALUE), propget]HRESULT Item([in] VARIANT Key, [out, retval] IFile** ppfile);
 				VARIANT var0;
 				V_VT(&var0) = VT_EMPTY;
-				VariantChangeType(&var0, &pDispParams->rgvarg[--index], 0, VT_VARIANT);
+				VariantCopyInd(&var0, &pDispParams->rgvarg[--index]);
 				V_VT(&res) = VT_DISPATCH;
 				hres = filecoll_get_Item(iface, var0, (IFile**)&V_DISPATCH(&res));
 				VariantClear(&var0);
@@ -1322,7 +1322,7 @@ static HRESULT WINAPI foldercoll_Invoke(IFolderCollection *iface, DISPID dispIdM
 				// line 464: [id(DISPID_VALUE), propget]HRESULT Item([in] VARIANT Key, [out, retval] IFolder** ppfolder);
 				VARIANT var0;
 				V_VT(&var0) = VT_EMPTY;
-				VariantChangeType(&var0, &pDispParams->rgvarg[--index], 0, VT_VARIANT);
+				VariantCopyInd(&var0, &pDispParams->rgvarg[--index]);
 				V_VT(&res) = VT_DISPATCH;
 				hres = foldercoll_get_Item(iface, var0, (IFolder**)&V_DISPATCH(&res));
 				VariantClear(&var0);
diff --git a/wine/dlls/vbscript/regexp_proxy.c b/wine/dlls/vbscript/regexp_proxy.c
index 47c7264..2abc030 100644
--- a/wine/dlls/vbscript/regexp_proxy.c
+++ b/wine/dlls/vbscript/regexp_proxy.c
@@ -308,7 +308,7 @@ static HRESULT WINAPI RegExp2_Invoke(IRegExp2 *iface, DISPID dispIdMember,
 				VariantChangeType(&var0, &pDispParams->rgvarg[--index], 0, VT_BSTR);
 				VARIANT var1;
 				V_VT(&var1) = VT_EMPTY;
-				VariantChangeType(&var1, &pDispParams->rgvarg[--index], 0, VT_VARIANT);
+				VariantCopyInd(&var1, &pDispParams->rgvarg[--index]);
 				V_VT(&res) = VT_BSTR;
 				hres = RegExp2_Replace(iface, V_BSTR(&var0), var1, &V_BSTR(&res));
 				VariantClear(&var0);
-- 
2.54.0

